install_target: first FORCE
	@test -d $(INSTALL_ROOT)/usr/tests/tests || mkdir -p $(INSTALL_ROOT)/usr/tests/tests
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/usr/tests/tests/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/usr/tests/tests/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/tests/tests/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

.SUFFIXES:

