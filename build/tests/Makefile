backend.o: ../../backend.cpp ../../backend.h \
		../../ffmpeg.h \
		../../filepicker.h \
		../../portalfilepicker.h \
		../../thumbprovider.h \
		../../thumbworker.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o backend.o ../../backend.cpp

ffmpeg.o: ../../ffmpeg.cpp ../../ffmpeg.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o ffmpeg.o ../../ffmpeg.cpp

portalfilepicker.o: ../../portalfilepicker.cpp ../../portalfilepicker.h \
		../../filepicker.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o portalfilepicker.o ../../portalfilepicker.cpp

thumbprovider.o: ../../thumbprovider.cpp ../../thumbprovider.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o thumbprovider.o ../../thumbprovider.cpp

thumbworker.o: ../../thumbworker.cpp ../../thumbworker.h \
		../../ffmpeg.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o thumbworker.o ../../thumbworker.cpp

moc_backend.o: moc_backend.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_backend.o moc_backend.cpp

moc_filepicker.o: moc_filepicker.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_filepicker.o moc_filepicker.cpp

moc_portalfilepicker.o: moc_portalfilepicker.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_portalfilepicker.o moc_portalfilepicker.cpp

moc_thumbworker.o: moc_thumbworker.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_thumbworker.o moc_thumbworker.cpp

