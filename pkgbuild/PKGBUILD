# Maintainer: David Heinemeier Hansson <david@hey.com>

pkgname=omacut
pkgver=0.1.1
pkgrel=1
pkgdesc='Dead-simple video length trimmer built with Qt Quick and ffmpeg'
arch=('x86_64')
url='https://github.com/omacom-io/omacut'
license=('MIT')
install='omacut.install'
depends=('ffmpeg' 'qt6-base' 'qt6-declarative' 'qt6-multimedia' 'xdg-desktop-portal')
makedepends=('gcc' 'make' 'qt6-base' 'qt6-declarative' 'qt6-multimedia')
source=()
sha256sums=()

build() {
  cd "$startdir/.."
  ./bin/build
}

package() {
  cd "$startdir/.."
  /usr/bin/install -Dm755 build/omacut "$pkgdir/usr/bin/omacut"
  /usr/bin/install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  /usr/bin/install -Dm644 "$startdir/omacut.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/omacut.svg"
  /usr/bin/install -Dm644 "$startdir/omacut.desktop" "$pkgdir/usr/share/applications/omacut.desktop"
}
